{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "incremental": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "extension", "src/**/*.test.ts", "src/**/*.e2e.test.ts", "src/selector-learning.ts", "src/selector-learning-engine.test.ts"]
}
